# NOTE: a root .pubignore REPLACES the root .gitignore for pub's file
# selection, so this file must re-state the .gitignore exclusions too.

# --- from .gitignore -------------------------------------------------------
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
*.iml
*.ipr
*.iws
.idea/
/pubspec.lock
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
/build/
/coverage/

# --- publish-only exclusions ------------------------------------------------
# Internal working documents — not part of the published package.
PLAN.md
IMPROVEMENTS.md
RULES.md
ARCHITECTURE.md
MIGRATION.md
docs/

# Generated Patrol test bundle (regenerated by `patrol build`).
example/patrol_test/test_bundle.dart
